{"entity_id":"char_v2_000003","entity_type":"character","display_name":"约伊兹","aliases":["约伊兹镇","约伊兹城"],"importance":"medium","summary":"赫萝声称自己出生的城镇，位于北方大地。罗伦斯指出约伊兹在古老传说中早已被熊怪毁灭，因此赫萝的出生地真实性存疑。赫萝对约伊兹的描述和情感反应表明她可能与该地有真实联系，但其真实性仍需进一步验证。","evidence_refs":["volume_01-c001-s003-p000253","volume_01-c001-s003-p000254","volume_01-c001-s004-p000259"],"dialogue_count":0,"first_seen_chunk_id":"volume_01-r000017","latest_seen_chunk_id":"volume_01-r000017","relationship_updates":[]}
